# Firebase 콘솔 > 프로젝트 설정 > 일반 > 내 앱 에서 복사한 값을 넣으세요.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firestore 문서 경로에 쓰이는 앱 식별자 (원하는 값으로 지정 가능)
VITE_APP_ID=eng-edu-app

# 관리자 로그인 비밀번호 (반드시 기존 admin1234! 에서 바꾸세요)
VITE_ADMIN_PASSWORD=change-me-before-deploying
